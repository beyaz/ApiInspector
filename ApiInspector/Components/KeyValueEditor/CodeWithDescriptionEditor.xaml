<UserControl x:Class="ApiInspector.Components.KeyValueEditor.CodeWithDescriptionEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wpfControls = "http://wpfcontrols.com/"
             mc:Ignorable="d" 
             x:Name = "CodeBehind"
             DataContext = "{Binding ElementName=CodeBehind}" 
             d:DesignWidth="300">
    <StackPanel>
        <Label FontWeight="Bold" Content="{Binding Label, Mode = OneWay}" />
        <wpfControls:AutoCompleteTextBox Provider="{Binding ElementName=CodeBehind}" Text="{Binding Text,Mode=TwoWay}" ></wpfControls:AutoCompleteTextBox>
    </StackPanel>
</UserControl>
