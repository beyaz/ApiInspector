<Window x:Class = "ApiInspector.MainWindow.View"
        xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:invocationInfoEditor = "clr-namespace:ApiInspector.InvocationInfoEditor"
        mc:Ignorable = "d"
        x:Name = "CodeBehind"
        DataContext = "{Binding ElementName=CodeBehind}"
        Title = "View" Height = "700" Width = "900" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height = "*" />
            <RowDefinition Height = "5" />
            <RowDefinition Height = "100" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "5*" />
            <ColumnDefinition Width = "5" />
            <ColumnDefinition Width = "5*" />
        </Grid.ColumnDefinitions>
        <Grid Margin = "5" >
            <Grid.RowDefinitions>
                <RowDefinition Height = "Auto" />
                <RowDefinition Height = "*" />
            </Grid.RowDefinitions>
            <StackPanel>
                <Label FontWeight = "Bold" >History</Label>
                <TextBox x:Name = "historyFilterTextBox" TextChanged = "HistoryFilterTextBox_OnTextChanged" />
            </StackPanel>
            <ListBox Grid.Row = "1" x:Name = "historyListBox" SelectionChanged = "HistoryListBox_OnSelected" />
        </Grid>

        <GridSplitter Grid.Row = "0" Grid.Column = "1" Width = "5" HorizontalAlignment = "Stretch" />

        <Grid Grid.Column = "2" Grid.Row = "0" Margin = "5" >
            <Grid.RowDefinitions>
                <RowDefinition Height = "Auto" />
                <RowDefinition Height = "*" />
                <RowDefinition Height = "Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Button HorizontalAlignment = "Right" x:Name = "executeButton" Click = "OnExecuteClicked" > Execute</Button>

                <invocationInfoEditor:View x:Name = "currentInvocationInfo" Margin = "0,10,0,0" />

                <StackPanel Margin = "0,10,0,0" >
                    <Label FontWeight = "Bold" > Response </Label>
                </StackPanel>

            </StackPanel>

            <RichTextBox Grid.Row = "1" Height = "Auto" x:Name = "invokingResponseView" />

            <Grid Grid.Row = "2" Margin = "0,4,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width = "Auto" />
                    <ColumnDefinition Width = "*" />
                </Grid.ColumnDefinitions>
                <Label FontWeight = "Bold" > Response Output File: </Label>
                <TextBox Grid.Column = "1" x:Name = "responseOutputFilePath"
                         TextChanged = "ResponseOutputFilePath_OnTextChanged" />
            </Grid>
        </Grid>

        <GridSplitter Grid.Row = "1" Grid.Column = "0" Grid.ColumnSpan = "3" Height = "5"
                      HorizontalAlignment = "Stretch" />
        <RichTextBox Grid.Column = "0" Grid.Row = "2" Grid.ColumnSpan = "3" VerticalScrollBarVisibility = "Auto"
                     x:Name = "traceViewer" />

    </Grid>
</Window>